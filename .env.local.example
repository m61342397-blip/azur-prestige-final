# ─── Resend (emails) ────────────────────────────────────
# 1. Créer un compte gratuit sur resend.com
# 2. Générer une API key dans Resend > API Keys
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXX

# Email qui reçoit les nouvelles réservations (toi, le chauffeur)
CHAUFFEUR_EMAIL=contact@azurprestige.eu

# Email expéditeur — doit être un domaine vérifié dans Resend
# En attendant la vérification du domaine, utilise : onboarding@resend.dev
FROM_EMAIL=reservations@azurprestige.eu

# ─── Supabase (base de données) — OPTIONNEL ─────────────
# Si tu veux stocker les réservations, créer un projet sur supabase.com
# Puis créer la table "reservations" avec les colonnes du README
NEXT_PUBLIC_SUPABASE_URL=https://XXXXX.supabase.co
SUPABASE_SERVICE_KEY=eyXXXXXXXXXXXXXXXXXXXXXX
